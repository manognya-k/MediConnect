<?xml version="1.0"?>
<?mso-application progid="Excel.Sheet"?>
<Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet"
 xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet">
 <Styles>
  <Style ss:ID="title">
   <Alignment ss:Horizontal="Center" ss:Vertical="Center"/>
   <Font ss:Bold="1" ss:Size="13" ss:Color="#7F1D1D"/>
   <Interior ss:Color="#FFF1F1" ss:Pattern="Solid"/>
  </Style>
  <Style ss:ID="hdr">
   <Alignment ss:Horizontal="Center" ss:Vertical="Center" ss:WrapText="1"/>
   <Font ss:Bold="1" ss:Size="11" ss:Color="#FFFFFF"/>
   <Interior ss:Color="#991B1B" ss:Pattern="Solid"/>
   <Borders><Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="2" ss:Color="#7F1D1D"/><Border ss:Position="Right" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#CCCCCC"/></Borders>
  </Style>
  <Style ss:ID="sno">
   <Alignment ss:Horizontal="Center" ss:Vertical="Top"/>
   <Font ss:Size="10"/>
   <Borders><Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E5E7EB"/><Border ss:Position="Right" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E5E7EB"/></Borders>
  </Style>
  <Style ss:ID="req">
   <Alignment ss:Horizontal="Center" ss:Vertical="Top" ss:WrapText="1"/>
   <Font ss:Size="10" ss:Bold="1" ss:Color="#991B1B"/>
   <Borders><Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E5E7EB"/><Border ss:Position="Right" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E5E7EB"/></Borders>
  </Style>
  <Style ss:ID="normal">
   <Alignment ss:Vertical="Top" ss:WrapText="1"/>
   <Font ss:Size="10"/>
   <Borders><Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E5E7EB"/><Border ss:Position="Right" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E5E7EB"/></Borders>
  </Style>
  <Style ss:ID="mod_Landing_Page">
   <Alignment ss:Horizontal="Center" ss:Vertical="Top" ss:WrapText="1"/>
   <Font ss:Size="10" ss:Bold="1" ss:Color="#E65100"/>
   <Interior ss:Color="#FFF3E0" ss:Pattern="Solid"/>
   <Borders><Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E5E7EB"/><Border ss:Position="Right" ss:LineStyle="Continuous" ss:Weight="2" ss:Color="#FB8C00"/></Borders>
  </Style>
  <Style ss:ID="mod_Authentication">
   <Alignment ss:Horizontal="Center" ss:Vertical="Top" ss:WrapText="1"/>
   <Font ss:Size="10" ss:Bold="1" ss:Color="#0D47A1"/>
   <Interior ss:Color="#E3F2FD" ss:Pattern="Solid"/>
   <Borders><Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E5E7EB"/><Border ss:Position="Right" ss:LineStyle="Continuous" ss:Weight="2" ss:Color="#1E88E5"/></Borders>
  </Style>
  <Style ss:ID="mod_Profile_Page">
   <Alignment ss:Horizontal="Center" ss:Vertical="Top" ss:WrapText="1"/>
   <Font ss:Size="10" ss:Bold="1" ss:Color="#1B5E20"/>
   <Interior ss:Color="#E8F5E9" ss:Pattern="Solid"/>
   <Borders><Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E5E7EB"/><Border ss:Position="Right" ss:LineStyle="Continuous" ss:Weight="2" ss:Color="#43A047"/></Borders>
  </Style>
  <Style ss:ID="mod_Library_Page">
   <Alignment ss:Horizontal="Center" ss:Vertical="Top" ss:WrapText="1"/>
   <Font ss:Size="10" ss:Bold="1" ss:Color="#F57F17"/>
   <Interior ss:Color="#FFF8E1" ss:Pattern="Solid"/>
   <Borders><Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E5E7EB"/><Border ss:Position="Right" ss:LineStyle="Continuous" ss:Weight="2" ss:Color="#FDD835"/></Borders>
  </Style>
  <Style ss:ID="mod_AI_Chatbot">
   <Alignment ss:Horizontal="Center" ss:Vertical="Top" ss:WrapText="1"/>
   <Font ss:Size="10" ss:Bold="1" ss:Color="#880E4F"/>
   <Interior ss:Color="#FCE4EC" ss:Pattern="Solid"/>
   <Borders><Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E5E7EB"/><Border ss:Position="Right" ss:LineStyle="Continuous" ss:Weight="2" ss:Color="#E91E63"/></Borders>
  </Style>
  <Style ss:ID="mod_Navigation">
   <Alignment ss:Horizontal="Center" ss:Vertical="Top" ss:WrapText="1"/>
   <Font ss:Size="10" ss:Bold="1" ss:Color="#311B92"/>
   <Interior ss:Color="#EDE7F6" ss:Pattern="Solid"/>
   <Borders><Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E5E7EB"/><Border ss:Position="Right" ss:LineStyle="Continuous" ss:Weight="2" ss:Color="#7E57C2"/></Borders>
  </Style>
 </Styles>
 <Worksheet ss:Name="Test Scenarios">
  <Table>
   <Column ss:Width="110"/>
   <Column ss:Width="45"/>
   <Column ss:Width="90"/>
   <Column ss:Width="200"/>
   <Column ss:Width="300"/>
   <Column ss:Width="130"/>
   <Row ss:Height="28">
    <Cell ss:MergeAcross="5" ss:StyleID="title"><Data ss:Type="String">BookedIn – Test Scenario Document | Version 1.0 | April 2026</Data></Cell>
   </Row>
   <Row ss:Height="32"><Cell ss:StyleID="hdr"><Data ss:Type="String">Module</Data></Cell><Cell ss:StyleID="hdr"><Data ss:Type="String">S.No</Data></Cell><Cell ss:StyleID="hdr"><Data ss:Type="String">Scenario ID</Data></Cell><Cell ss:StyleID="hdr"><Data ss:Type="String">Scenario Name</Data></Cell><Cell ss:StyleID="hdr"><Data ss:Type="String">Scenario Description</Data></Cell><Cell ss:StyleID="hdr"><Data ss:Type="String">Requirement ID</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Landing_Page"><Data ss:Type="String">Landing Page</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">1</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_LP_01</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate BookedIn Logo Display</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that the BookedIn logo is displayed at the top-left corner of the landing page.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_01</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Landing_Page"><Data ss:Type="String">Landing Page</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">2</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_LP_02</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Log In and Sign Up Button Visibility</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that both Log In and Sign Up buttons are visible at the top-right corner of the landing page.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_02</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Landing_Page"><Data ss:Type="String">Landing Page</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">3</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_LP_03</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Log In and Sign Up Button Navigation</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that clicking Log In navigates to the login screen and Sign Up navigates to the registration screen.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_02</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Landing_Page"><Data ss:Type="String">Landing Page</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">4</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_LP_04</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Hero Section Content and CTA</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that the headline 'Let's connect ?' and the Get Started button are displayed in the hero section and that clicking Get Started initiates account creation.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_03, REQ_04</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Landing_Page"><Data ss:Type="String">Landing Page</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">5</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_LP_05</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate 7 Alternating Content Blocks</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that all 7 main content blocks are displayed in alternating layout describing core platform features.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_05</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Landing_Page"><Data ss:Type="String">Landing Page</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">6</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_LP_06</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Obsidian and Crimson Color Theme</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that the landing page uses a high-contrast Obsidian and Crimson color theme throughout.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_06</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Landing_Page"><Data ss:Type="String">Landing Page</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">7</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_LP_07</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate AI Chatbot Icon and Behaviour on Landing Page</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that the AI Chatbot icon is anchored at the bottom-right and clicking it expands the chatbot window.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_07, REQ_08</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Landing_Page"><Data ss:Type="String">Landing Page</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">8</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_LP_08</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Landing Page Responsiveness</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that the landing page layout adapts correctly across desktop, tablet, and mobile devices.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_09</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Authentication"><Data ss:Type="String">Authentication</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">1</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_AU_01</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Successful User Registration</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that a new user can register with a unique email and valid credentials and that the account is created successfully.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_10</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Authentication"><Data ss:Type="String">Authentication</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">2</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_AU_02</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Duplicate Email Registration Restriction</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that the system prevents registration with a duplicate email and displays an appropriate error message.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_11</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Authentication"><Data ss:Type="String">Authentication</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">3</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_AU_03</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Mandatory Fields on Registration</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that submitting the registration form with empty mandatory fields displays validation error messages.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_12</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Authentication"><Data ss:Type="String">Authentication</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">4</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_AU_04</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Login with Valid and Invalid Credentials</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that a registered user can log in with valid credentials and that invalid password or unregistered email shows appropriate error messages.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_13, REQ_14</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Authentication"><Data ss:Type="String">Authentication</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">5</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_AU_05</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate User Logout Functionality</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that a logged-in user can log out and is redirected to the landing page.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_15</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Authentication"><Data ss:Type="String">Authentication</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">6</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_AU_06</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Session Persistence on Page Refresh</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that the user session is maintained after a page refresh and the user remains logged in.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_16</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Profile_Page"><Data ss:Type="String">Profile Page</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">1</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_PP_01</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Profile Page Navigation Bar</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that the Profile page displays navigation links for Home, Library, and Messages and that the Profile tab is highlighted in Crimson.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_17, REQ_18</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Profile_Page"><Data ss:Type="String">Profile Page</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">2</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_PP_02</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate User Identity Card Stats Display</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that the User Identity Card displays Books Read, Currently Reading, and Connections counts accurately.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_19</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Profile_Page"><Data ss:Type="String">Profile Page</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">3</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_PP_03</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Bio and Membership Date Display</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that the profile page displays the user's bio and membership start date correctly.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_20</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Profile_Page"><Data ss:Type="String">Profile Page</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">4</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_PP_04</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Edit Profile Functionality</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that clicking Edit Profile allows the user to update metadata and that changes are saved and immediately reflected on the profile page.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_21, REQ_22</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Profile_Page"><Data ss:Type="String">Profile Page</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">5</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_PP_05</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Favorite Genres and Books Display</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that Favorite Genres are displayed as Crimson badges and Favorite Books are shown as a visual gallery of book covers.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_23, REQ_24</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Profile_Page"><Data ss:Type="String">Profile Page</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">6</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_PP_06</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate 2026 Reading Goal Progress Bar</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that the Reading Goal progress bar is displayed in Crimson and that the percentage accurately reflects books read against the annual goal.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_25, REQ_26</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Profile_Page"><Data ss:Type="String">Profile Page</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">7</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_PP_07</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate AI Chatbot Icon on Profile Page</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that the AI Chatbot icon is persistently visible at the bottom-right of the profile page.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_27</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Library_Page"><Data ss:Type="String">Library Page</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">1</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_LB_01</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Library Page Navigation Bar and Active Tab</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that the Library page displays all navigation links and that the Library tab is highlighted in Crimson.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_28, REQ_29</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Library_Page"><Data ss:Type="String">Library Page</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">2</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_LB_02</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Currently Reading Shelf and Progress Display</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that the Currently Reading shelf displays active titles with Crimson progress bars and correct percentage complete metrics.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_30, REQ_31</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Library_Page"><Data ss:Type="String">Library Page</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">3</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_LB_03</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Completed and Want to Read Shelf Display</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that the Completed shelf shows finished book covers and the Want to Read shelf displays wishlisted titles correctly.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_32, REQ_33</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Library_Page"><Data ss:Type="String">Library Page</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">4</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_LB_04</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Numerical Badge Count on Each Shelf</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that each shelf displays a numerical badge showing the total number of books and that the count updates dynamically on add/remove.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_34, REQ_38</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Library_Page"><Data ss:Type="String">Library Page</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">5</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_LB_05</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Book Shelf Transition Functionality</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that a user can add a book to Want to Read, move it to Currently Reading, and mark it as Completed with correct shelf transitions.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_35, REQ_36, REQ_37</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_AI_Chatbot"><Data ss:Type="String">AI Chatbot</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">1</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_AI_01</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate AI Chatbot Persistence Across All Pages</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that the AI Chatbot icon is persistently visible at the bottom-right on all pages and that clicking it expands the chatbot window.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_39, REQ_40</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_AI_Chatbot"><Data ss:Type="String">AI Chatbot</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">2</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_AI_02</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Chatbot Genre-Based Recommendation</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that the chatbot accepts natural language genre input and returns relevant book recommendations.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_41, REQ_42</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_AI_Chatbot"><Data ss:Type="String">AI Chatbot</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">3</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_AI_03</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Chatbot Movie-Based Book Recommendation</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that the chatbot returns book recommendations based on movie input.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_43</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_AI_Chatbot"><Data ss:Type="String">AI Chatbot</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">4</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_AI_04</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Chatbot Empty Input and Close Behaviour</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that the chatbot handles empty input gracefully with a prompt/error and that the chatbot window can be closed or minimized.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_44, REQ_45</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_AI_Chatbot"><Data ss:Type="String">AI Chatbot</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">5</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_AI_05</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Chatbot Response Time</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that the chatbot returns a response within the acceptable time limit of 3–5 seconds.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_46</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Navigation"><Data ss:Type="String">Navigation</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">1</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_NV_01</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Navigation Links Functionality</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that clicking Home, Library, Messages, and Profile navigation links correctly redirects the user to the respective pages.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_47, REQ_48, REQ_49, REQ_50</Data></Cell></Row><Row ss:Height="50"><Cell ss:StyleID="mod_Navigation"><Data ss:Type="String">Navigation</Data></Cell><Cell ss:StyleID="sno"><Data ss:Type="Number">2</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">TS_NV_02</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Validate Active Tab Highlighting in Navigation Bar</Data></Cell><Cell ss:StyleID="normal"><Data ss:Type="String">Verify that the currently active page tab is highlighted in Crimson in the navigation bar across all pages.</Data></Cell><Cell ss:StyleID="req"><Data ss:Type="String">REQ_51</Data></Cell></Row></Table></Worksheet></Workbook>